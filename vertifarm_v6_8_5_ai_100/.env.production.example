# ════════════════════════════════════════════════════════════
#  VertiFarm OS — PRODUCTION Environment
#  Use this on your server. All values must be changed!
# ════════════════════════════════════════════════════════════

# ─── App ────────────────────────────────────────────────────
ENVIRONMENT=production
APP_NAME=VertiFarm OS
APP_VERSION=1.0.0

# ─── CHANGE THESE! ──────────────────────────────────────────
POSTGRES_DB=vertifarm
POSTGRES_USER=vertifarm_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_STRING_HERE

# ─── Admin account ──────────────────────────────────────────
FIRST_SUPERUSER_EMAIL=admin@yourdomain.com
FIRST_SUPERUSER_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ─── URLs (your server's domain/IP) ─────────────────────────
VITE_API_URL=https://yourdomain.com
VITE_WS_URL=wss://yourdomain.com

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ─── Database URL (auto-built from above) ───────────────────
DATABASE_URL=postgresql+asyncpg://vertifarm_prod:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/vertifarm
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD_HERE@redis:6379/0

# ─── Email (optional) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=your_smtp_app_password
EMAILS_FROM_EMAIL=noreply@yourdomain.com

# ─── Security ────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
