# ════════════════════════════════════════════════════
#  VertiFarm OS — Environment Configuration
#  Copy this file to .env and update values
# ════════════════════════════════════════════════════

# ─── App ───────────────────────────────────────────
ENVIRONMENT=development          # development | production
APP_NAME="VertiFarm OS"
APP_VERSION=1.0.0

# ─── Database ──────────────────────────────────────
POSTGRES_DB=vertifarm
POSTGRES_USER=vertifarm
POSTGRES_PASSWORD=vertifarm_secret_2024
DATABASE_URL=postgresql+asyncpg://vertifarm:vertifarm_secret_2024@localhost:5432/vertifarm

# ─── Redis ─────────────────────────────────────────
REDIS_PASSWORD=redis_secret_2024
REDIS_URL=redis://:redis_secret_2024@localhost:6379/0

# ─── Security ──────────────────────────────────────
# REQUIRED in production — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# If left blank the server generates a per-process key and all sessions
# are invalidated on every restart.
SECRET_KEY=                            # ← FILL THIS IN
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── CORS ──────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,http://localhost:80

# ─── Admin User ────────────────────────────────────
FIRST_SUPERUSER_EMAIL=admin@vertifarm.io
FIRST_SUPERUSER_PASSWORD=Admin@123456

# ─── Frontend ──────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ─── Email (optional) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
EMAILS_FROM_EMAIL=noreply@vertifarm.io
